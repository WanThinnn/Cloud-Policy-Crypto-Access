# Django Configuration
DJANGO_ENV=development
DJANGO_SECRET_KEY=your-secret-key-here-generate-a-strong-one
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ==========================================
# Database Configuration
# ==========================================
# OPTION 1: Cloud Database (Supabase PostgreSQL - Recommended for Production)
# Enter your PostgreSQL connection URL here (Uncomment to use)
# DATABASE_URL=postgresql://postgres.xxx:password@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres

# OPTION 2: Local Database (SQLite - For Testing/Development Offline)
# If you use Local SQLite, the database file will be stored in the DB_DIR directory on your host.
DATABASE_URL=sqlite:////app/data/db.sqlite3

# DB_DIR: The directory on your host machine to mount the SQLite database (e.g., ./data)
# (Data remains safe in this directory even if containers are destroyed)
DB_DIR=./data

# ==========================================
# Storage Configuration
# ==========================================
# CRITICAL NOTE:
# Regardless of whether you use Local Database or Cloud Database above,
# ALL ENCRYPTED CP-ABE FILES MUST be stored on Supabase Cloud Storage.
# The system does not support storing encrypted files on local disk to ensure high security.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# CPABE Keys Configuration
# KEYS_DIR: Path to CPABE keys folder on host (e.g. ./keys). Leave blank to use container volume.
KEYS_DIR=

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com

# Redis Configuration (for caching and sessions)
REDIS_URL=redis://127.0.0.1:6379/1
REDIS_USE_TLS=False

# Admin Configuration
ADMIN_EMAIL=admin@example.com

# Third-party Service Keys (if needed)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
